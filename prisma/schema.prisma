  master_trip_question master_trip_question @relation(fields: [master_question_id], references: [question_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tq_master")
  trip                 trip                 @relation(fields: [trip_id], references: [trip_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_tq_trip")
}

model master_document {
  document_id       String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  document_code     String              @unique @db.VarChar(50)
  document_name     String              @db.VarChar(150)
  description       String?
  is_lead           Boolean?            @default(true)
  is_pax            Boolean?            @default(true)
  is_mandatory      Boolean?            @default(false)
  is_active         Boolean?            @default(true)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  created_by        String?             @db.Uuid
  modified_at       DateTime?           @db.Timestamp(6)
  modified_by       String?             @db.Uuid
  trip_pax_document trip_pax_document[]
}
