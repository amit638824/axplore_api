generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:12345@localhost:5432/axplore_arun?schema=public"
}

model MasterCountry {
  countryId    String                        @id @default(dbgenerated("uuid_generate_v4()")) @map("country_id") @db.Uuid
  name         String                        @unique @map("name") @db.VarChar(100)
  isoCode      String?                       @map("iso_code") @db.VarChar(10)
  subDivisions CorporateSubDivisionAddress[]
  leadFrom     LeadDestination[]             @relation("LeadFromCountry")
  leadTo       LeadDestination[]             @relation("LeadToCountry")
  states       MasterState[]
  branches     TravelAgencyBranch[]

  @@map("master_country")
}

model MasterState {
  stateId      String                        @id @default(dbgenerated("uuid_generate_v4()")) @map("state_id") @db.Uuid
  countryId    String                        @map("country_id") @db.Uuid
  name         String                        @map("name") @db.VarChar(100)
  subDivisions CorporateSubDivisionAddress[]
  cities       MasterCity[]
  country      MasterCountry                 @relation(fields: [countryId], references: [countryId], onDelete: NoAction, onUpdate: NoAction, map: "fk_state_country")
  branches     TravelAgencyBranch[]

  @@unique([countryId, name])
  @@map("master_state")
}

model MasterCity {
  cityId            String                        @id @default(dbgenerated("uuid_generate_v4()")) @map("city_id") @db.Uuid
  stateId           String                        @map("state_id") @db.Uuid
  name              String                        @map("name") @db.VarChar(100)
  city_image        String?
  subDivisions      CorporateSubDivisionAddress[]
  leadFrom          LeadDestination[]             @relation("LeadFromCity")
  leadTo            LeadDestination[]             @relation("LeadToCity")
  state             MasterState                   @relation(fields: [stateId], references: [stateId], onDelete: NoAction, onUpdate: NoAction, map: "fk_city_state")
  master_pickup_hub master_pickup_hub[]
  branches          TravelAgencyBranch[]

  @@unique([stateId, name])
  @@map("master_city")
}

model MasterDesignation {
  designationId   String    @id @default(dbgenerated("uuid_generate_v4()")) @map("designation_id") @db.Uuid
  designationCode String    @unique @map("designation_code") @db.VarChar(50)
  designationName String    @map("designation_name") @db.VarChar(150)
  isActive        Boolean?  @default(true) @map("is_active")
  users           AppUser[]

  @@map("master_designation")
}

model MasterLeadSegment {
  leadSegmentId String    @id @default(dbgenerated("uuid_generate_v4()")) @map("lead_segment_id") @db.Uuid
  segmentCode   String    @unique @map("segment_code") @db.VarChar(50)
  segmentName   String    @map("segment_name") @db.VarChar(150)
  description   String?   @map("description")
  displayOrder  Int?      @map("display_order")
  isActive      Boolean?  @default(true) @map("is_active")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  leads         Lead[]

  @@map("master_lead_segment")
}

model MasterLeadStatus {
  leadStatusId String    @id @default(dbgenerated("uuid_generate_v4()")) @map("lead_status_id") @db.Uuid
  statusCode   String    @unique @map("status_code") @db.VarChar(50)
  statusName   String    @map("status_name") @db.VarChar(150)
  description  String?   @map("description")
  displayOrder Int?      @map("display_order")
  isActive     Boolean?  @default(true) @map("is_active")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  leads        Lead[]

  @@map("master_lead_status")
}

model MasterServiceCategory {
  serviceCategoryId String              @id @default(dbgenerated("uuid_generate_v4()")) @map("service_category_id") @db.Uuid
  categoryCode      String              @unique @map("category_code") @db.VarChar(50)
  categoryName      String              @map("category_name") @db.VarChar(150)
  description       String?             @map("description")
  displayOrder      Int?                @map("display_order")
  isActive          Boolean?            @default(true) @map("is_active")
  createdAt         DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  serviceTypes      MasterServiceType[]

  @@map("master_service_category")
}

model MasterServiceType {
  serviceTypeId     String                @id @default(dbgenerated("uuid_generate_v4()")) @map("service_type_id") @db.Uuid
  serviceCategoryId String                @map("service_category_id") @db.Uuid
  serviceTypeCode   String                @map("service_type_code") @db.VarChar(50)
  serviceTypeName   String                @map("service_type_name") @db.VarChar(150)
  description       String?               @map("description")
  displayOrder      Int?                  @map("display_order")
  isActive          Boolean?              @default(true) @map("is_active")
  createdAt         DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  category          MasterServiceCategory @relation(fields: [serviceCategoryId], references: [serviceCategoryId], onDelete: Cascade, onUpdate: NoAction, map: "fk_service_type_category")

  @@unique([serviceCategoryId, serviceTypeCode], map: "uq_service_type_code")
  @@map("master_service_type")
}

model MasterServiceLevel {
  serviceLevelId String   @id @default(dbgenerated("uuid_generate_v4()")) @map("service_level_id") @db.Uuid
  levelCode      String   @unique @map("level_code") @db.VarChar(50)
  levelName      String   @map("level_name") @db.VarChar(100)
  displayOrder   Int?     @map("display_order")
  isActive       Boolean? @default(true) @map("is_active")

  @@map("master_service_level")
}

model TravelAgency {
  travelAgencyId String                @id @default(dbgenerated("uuid_generate_v4()")) @map("travel_agency_id") @db.Uuid
  name           String                @map("name") @db.VarChar(200)
  email          String?               @map("email") @db.VarChar(150)
  phone          String?               @map("phone") @db.VarChar(50)
  websiteUrl     String?               @map("website_url")
  description    String?               @map("description")
  facebookUrl    String?               @map("facebook_url")
  instagramUrl   String?               @map("instagram_url")
  linkedinUrl    String?               @map("linkedin_url")
  twitterUrl     String?               @map("twitter_url")
  youtubeUrl     String?               @map("youtube_url")
  isActive       Boolean?              @default(true) @map("is_active")
  createdAt      DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  users          AppUser[]
  branches       TravelAgencyBranch[]
  settings       TravelAgencySettings?

  @@map("travel_agency")
}

model TravelAgencyBranch {
  branchId       String        @id @default(dbgenerated("uuid_generate_v4()")) @map("branch_id") @db.Uuid
  travelAgencyId String        @map("travel_agency_id") @db.Uuid
  branchName     String        @map("branch_name") @db.VarChar(150)
  branchCode     String?       @map("branch_code") @db.VarChar(50)
  phone          String?       @map("phone") @db.VarChar(50)
  email          String?       @map("email") @db.VarChar(150)
  countryId      String        @map("country_id") @db.Uuid
  stateId        String        @map("state_id") @db.Uuid
  cityId         String        @map("city_id") @db.Uuid
  isActive       Boolean?      @default(true) @map("is_active")
  createdAt      DateTime?     @default(now()) @map("created_at") @db.Timestamp(6)
  app_user       AppUser[]
  salesLeads     Lead[]        @relation("SalesBranch")
  travelAgency   TravelAgency  @relation(fields: [travelAgencyId], references: [travelAgencyId], onDelete: Cascade, onUpdate: NoAction, map: "fk_branch_agency")
  city           MasterCity    @relation(fields: [cityId], references: [cityId], onDelete: NoAction, onUpdate: NoAction, map: "fk_branch_city")
  country        MasterCountry @relation(fields: [countryId], references: [countryId], onDelete: NoAction, onUpdate: NoAction, map: "fk_branch_country")
  state          MasterState   @relation(fields: [stateId], references: [stateId], onDelete: NoAction, onUpdate: NoAction, map: "fk_branch_state")

  @@unique([branchId, travelAgencyId], map: "uq_branch_agency_pair")
  @@unique([travelAgencyId, branchCode], map: "uq_branch_code_per_agency")
  @@index([travelAgencyId], map: "idx_branch_agency")
  @@map("travel_agency_branch")
}

model TravelAgencySettings {
  travelAgencySettingsId String       @id @default(dbgenerated("uuid_generate_v4()")) @map("travel_agency_settings_id") @db.Uuid
  travelAgencyId         String       @unique(map: "uq_agency_settings") @map("travel_agency_id") @db.Uuid
  smtpHost               String?      @map("smtp_host") @db.VarChar(200)
  smtpPort               Int?         @map("smtp_port")
  smtpUsername           String?      @map("smtp_username") @db.VarChar(200)
  smtpPassword           String?      @map("smtp_password")
  smtpFromEmail          String?      @map("smtp_from_email") @db.VarChar(200)
  smtpFromName           String?      @map("smtp_from_name") @db.VarChar(200)
  smtpUseTls             Boolean?     @default(true) @map("smtp_use_tls")
  paymentProvider        String?      @map("payment_provider") @db.VarChar(100)
  paymentPublicKey       String?      @map("payment_public_key")
  paymentSecretKey       String?      @map("payment_secret_key")
  paymentWebhookUrl      String?      @map("payment_webhook_url")
  isActive               Boolean?     @default(true) @map("is_active")
  createdAt              DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt              DateTime?    @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  s3_bucket_name         String?
  s3_region              String?
  s3_access_key_id       String?
  s3_secret_access_key   String?
  s3_base_url            String?
  travelAgency           TravelAgency @relation(fields: [travelAgencyId], references: [travelAgencyId], onDelete: Cascade, onUpdate: NoAction, map: "fk_agency_settings_agency")

  @@map("travel_agency_settings")
}

model AppUser {
  userId                                                           String                 @id @default(dbgenerated("uuid_generate_v4()")) @map("user_id") @db.Uuid
  travelAgencyId                                                   String                 @map("travel_agency_id") @db.Uuid
  branchId                                                         String                 @map("branch_id") @db.Uuid
  designationId                                                    String                 @map("designation_id") @db.Uuid
  employeeCode                                                     String?                @map("employee_code") @db.VarChar(50)
  firstName                                                        String?                @map("first_name") @db.VarChar(100)
  lastName                                                         String?                @map("last_name") @db.VarChar(100)
  email                                                            String?                @map("email") @db.VarChar(150)
  mobile                                                           String?                @map("mobile") @db.VarChar(30)
  isActive                                                         Boolean?               @default(true) @map("is_active")
  createdAt                                                        DateTime?              @default(now()) @map("created_at") @db.Timestamp(6)
  travelAgency                                                     TravelAgency           @relation(fields: [travelAgencyId], references: [travelAgencyId], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_agency")
  travel_agency_branch                                             TravelAgencyBranch     @relation(fields: [branchId, travelAgencyId], references: [branchId, travelAgencyId], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_branch_and_agency")
  designation                                                      MasterDesignation      @relation(fields: [designationId], references: [designationId], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_designation")
  auth                                                             AppUserAuth?
  loginSessions                                                    AppUserLoginSession[]
  passwordResets                                                   AppUserPasswordReset[]
  contractingLeads                                                 Lead[]                 @relation("ContractingHead")
  createdLeads                                                     Lead[]                 @relation("CreatedBy")
  modifiedLeads                                                    Lead[]                 @relation("ModifiedBy")
  salesLeads                                                       Lead[]                 @relation("SalesUser")
  lead_contracting_team_lead_contracting_team_created_byToapp_user LeadContractingTeam[]  @relation("lead_contracting_team_created_byToapp_user")
  contractingTeamMembers                                           LeadContractingTeam[]
  createdDestinations                                              LeadDestination[]      @relation("CreatedBy")
  modifiedDestinations                                             LeadDestination[]      @relation("ModifiedBy")
  createdPickups                                                   LeadPickupHub[]        @relation("CreatedBy")
  modifiedPickups                                                  LeadPickupHub[]        @relation("ModifiedBy")
  createdTripInfo                                                  LeadTripInfo[]         @relation("CreatedBy")
  modifiedTripInfo                                                 LeadTripInfo[]         @relation("ModifiedBy")
  userRoles                                                        UserRole[]

  @@index([travelAgencyId], map: "idx_app_user_agency")
  @@index([branchId], map: "idx_app_user_branch")
  @@index([designationId], map: "idx_app_user_designation")
  @@map("app_user")
}

model AppUserAuth {
  userId              String    @id @map("user_id") @db.Uuid
  passwordHash        String    @map("password_hash")
  lastOtpCode         String?   @map("last_otp_code") @db.VarChar(10)
  otpExpiresAt        DateTime? @map("otp_expires_at") @db.Timestamp(6)
  isLocked            Boolean?  @default(false) @map("is_locked")
  failedLoginAttempts Int?      @default(0) @map("failed_login_attempts")
  lastLoginAt         DateTime? @map("last_login_at") @db.Timestamp(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime? @updatedAt @map("updated_at") @db.Timestamp(6)
  user                AppUser   @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_app_user_auth_user")

  @@map("app_user_auth")
}

model AppUserLoginSession {
  loginSessionId   String    @id @default(dbgenerated("uuid_generate_v4()")) @map("login_session_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  deviceId         String    @map("device_id") @db.VarChar(200)
  deviceType       String?   @map("device_type") @db.VarChar(50)
  deviceName       String?   @map("device_name") @db.VarChar(150)
  appVersion       String?   @map("app_version") @db.VarChar(50)
  ipAddress        String?   @map("ip_address") @db.VarChar(50)
  userAgent        String?   @map("user_agent")
  loginAt          DateTime  @default(now()) @map("login_at") @db.Timestamp(6)
  lastActivityAt   DateTime? @map("last_activity_at") @db.Timestamp(6)
  logoutAt         DateTime? @map("logout_at") @db.Timestamp(6)
  isActive         Boolean   @default(true) @map("is_active")
  terminatedReason String?   @map("terminated_reason") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  user             AppUser   @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_login_session_user")

  @@index([deviceId], map: "idx_login_session_device")
  @@index([userId], map: "idx_login_session_user")
  @@map("app_user_login_session")
}

model AppUserPasswordReset {
  passwordResetId    String    @id @default(dbgenerated("uuid_generate_v4()")) @map("password_reset_id") @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  resetToken         String    @unique(map: "uq_password_reset_token") @map("reset_token")
  expiresAt          DateTime  @map("expires_at") @db.Timestamp(6)
  usedAt             DateTime? @map("used_at") @db.Timestamp(6)
  requestedIp        String?   @map("requested_ip") @db.VarChar(50)
  requestedUserAgent String?   @map("requested_user_agent")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  user               AppUser   @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_password_reset_user")

  @@index([userId], map: "idx_password_reset_user")
  @@map("app_user_password_reset")
}

model Role {
  roleId          String           @id @default(dbgenerated("uuid_generate_v4()")) @map("role_id") @db.Uuid
  roleCode        String           @unique @map("role_code") @db.VarChar(50)
  roleName        String           @map("role_name") @db.VarChar(150)
  description     String?          @map("description")
  isActive        Boolean?         @default(true) @map("is_active")
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("role")
}

model Menu {
  menuId       String    @id @default(dbgenerated("uuid_generate_v4()")) @map("menu_id") @db.Uuid
  menuCode     String    @unique @map("menu_code") @db.VarChar(50)
  menuName     String    @map("menu_name") @db.VarChar(150)
  displayOrder Int?      @map("display_order")
  icon         String?   @map("icon") @db.VarChar(100)
  isActive     Boolean?  @default(true) @map("is_active")
  subMenus     SubMenu[]

  @@map("menu")
}

model SubMenu {
  subMenuId    String       @id @default(dbgenerated("uuid_generate_v4()")) @map("sub_menu_id") @db.Uuid
  menuId       String       @map("menu_id") @db.Uuid
  subMenuCode  String       @map("sub_menu_code") @db.VarChar(50)
  subMenuName  String       @map("sub_menu_name") @db.VarChar(150)
  routePath    String?      @map("route_path") @db.VarChar(200)
  displayOrder Int?         @map("display_order")
  isActive     Boolean?     @default(true) @map("is_active")
  permissions  Permission[]
  menu         Menu         @relation(fields: [menuId], references: [menuId], onDelete: Cascade, onUpdate: NoAction, map: "fk_sub_menu_menu")

  @@unique([menuId, subMenuCode], map: "uq_sub_menu_code")
  @@index([menuId], map: "idx_sub_menu_menu")
  @@map("sub_menu")
}

model Permission {
  permissionId    String           @id @default(dbgenerated("uuid_generate_v4()")) @map("permission_id") @db.Uuid
  subMenuId       String           @map("sub_menu_id") @db.Uuid
  permissionCode  String           @unique @map("permission_code") @db.VarChar(100)
  permissionName  String           @map("permission_name") @db.VarChar(150)
  description     String?          @map("description")
  isActive        Boolean?         @default(true) @map("is_active")
  subMenu         SubMenu          @relation(fields: [subMenuId], references: [subMenuId], onDelete: Cascade, onUpdate: NoAction, map: "fk_permission_sub_menu")
  rolePermissions RolePermission[]

  @@index([subMenuId], map: "idx_permission_sub_menu")
  @@map("permission")
}

model UserRole {
  userId String  @map("user_id") @db.Uuid
  roleId String  @map("role_id") @db.Uuid
  role   Role    @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction, map: "fk_ur_role")
  user   AppUser @relation(fields: [userId], references: [userId], onDelete: Cascade, onUpdate: NoAction, map: "fk_ur_user")

  @@id([userId, roleId])
  @@index([userId], map: "idx_user_role_user")
  @@map("user_role")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [permissionId], onDelete: Cascade, onUpdate: NoAction, map: "fk_rp_permission")
  role         Role       @relation(fields: [roleId], references: [roleId], onDelete: Cascade, onUpdate: NoAction, map: "fk_rp_role")

  @@id([roleId, permissionId])
  @@index([roleId], map: "idx_role_permission_role")
  @@map("role_permission")
}

model Corporate {
  corporateId    String                   @id @default(dbgenerated("uuid_generate_v4()")) @map("corporate_id") @db.Uuid
  corporateCode  String?                  @map("corporate_code") @db.VarChar(50)
  corporateName  String                   @unique(map: "uq_corporate_name") @map("corporate_name") @db.VarChar(200)
  websiteUrl     String?                  @map("website_url")
  isActive       Boolean?                 @default(true) @map("is_active")
  createdAt      DateTime?                @default(now()) @map("created_at") @db.Timestamp(6)
  contactPersons CorporateContactPerson[]
  divisions      CorporateDivision[]
  leads          Lead[]

  @@map("corporate")
}

model CorporateDivision {
  divisionId     String                   @id @default(dbgenerated("uuid_generate_v4()")) @map("division_id") @db.Uuid
  corporateId    String                   @map("corporate_id") @db.Uuid
  divisionCode   String?                  @map("division_code") @db.VarChar(50)
  divisionName   String                   @map("division_name") @db.VarChar(200)
  isActive       Boolean?                 @default(true) @map("is_active")
  createdAt      DateTime?                @default(now()) @map("created_at") @db.Timestamp(6)
  contactPersons CorporateContactPerson[]
  corporate      Corporate                @relation(fields: [corporateId], references: [corporateId], onDelete: Cascade, onUpdate: NoAction, map: "fk_division_corporate")
  subDivisions   CorporateSubDivision[]
  leads          Lead[]

  @@unique([corporateId, divisionName], map: "uq_division_per_corporate")
  @@index([corporateId], map: "idx_corp_div_corp")
  @@map("corporate_division")
}

model CorporateSubDivision {
  subDivisionId   String                        @id @default(dbgenerated("uuid_generate_v4()")) @map("sub_division_id") @db.Uuid
  divisionId      String                        @map("division_id") @db.Uuid
  subDivisionCode String?                       @map("sub_division_code") @db.VarChar(50)
  subDivisionName String                        @map("sub_division_name") @db.VarChar(200)
  websiteUrl      String?                       @map("website_url")
  isActive        Boolean?                      @default(true) @map("is_active")
  createdAt       DateTime?                     @default(now()) @map("created_at") @db.Timestamp(6)
  contactPersons  CorporateContactPerson[]
  division        CorporateDivision             @relation(fields: [divisionId], references: [divisionId], onDelete: Cascade, onUpdate: NoAction, map: "fk_sub_division_division")
  addresses       CorporateSubDivisionAddress[]
  leads           Lead[]

  @@unique([divisionId, subDivisionName], map: "uq_sub_division_per_division")
  @@index([divisionId], map: "idx_corp_sub_div_div")
  @@map("corporate_sub_division")
}

model CorporateSubDivisionAddress {
  subDivisionAddressId String               @id @default(dbgenerated("uuid_generate_v4()")) @map("sub_division_address_id") @db.Uuid
  subDivisionId        String               @map("sub_division_id") @db.Uuid
  addressLine1         String               @map("address_line1")
  addressLine2         String?              @map("address_line2")
  cityId               String               @map("city_id") @db.Uuid
  stateId              String               @map("state_id") @db.Uuid
  countryId            String               @map("country_id") @db.Uuid
  postalCode           String?              @map("postal_code") @db.VarChar(20)
  isPrimary            Boolean?             @default(true) @map("is_primary")
  createdAt            DateTime?            @default(now()) @map("created_at") @db.Timestamp(6)
  city                 MasterCity           @relation(fields: [cityId], references: [cityId], onDelete: NoAction, onUpdate: NoAction, map: "fk_sub_div_addr_city")
  country              MasterCountry        @relation(fields: [countryId], references: [countryId], onDelete: NoAction, onUpdate: NoAction, map: "fk_sub_div_addr_country")
  state                MasterState          @relation(fields: [stateId], references: [stateId], onDelete: NoAction, onUpdate: NoAction, map: "fk_sub_div_addr_state")
  subDivision          CorporateSubDivision @relation(fields: [subDivisionId], references: [subDivisionId], onDelete: Cascade, onUpdate: NoAction, map: "fk_sub_div_addr_sub_div")

  @@map("corporate_sub_division_address")
}

model CorporateContactPerson {
  contactPersonId String                @id @default(dbgenerated("uuid_generate_v4()")) @map("contact_person_id") @db.Uuid
  corporateId     String                @map("corporate_id") @db.Uuid
  divisionId      String?               @map("division_id") @db.Uuid
  subDivisionId   String?               @map("sub_division_id") @db.Uuid
  firstName       String                @map("first_name") @db.VarChar(100)
  lastName        String?               @map("last_name") @db.VarChar(100)
  designation     String?               @map("designation") @db.VarChar(150)
  email           String?               @map("email") @db.VarChar(150)
  mobile          String?               @map("mobile") @db.VarChar(30)
  alternateMobile String?               @map("alternate_mobile") @db.VarChar(30)
  location        String?               @map("location") @db.VarChar(150)
  isPrimary       Boolean?              @default(false) @map("is_primary")
  isActive        Boolean?              @default(true) @map("is_active")
  createdAt       DateTime?             @default(now()) @map("created_at") @db.Timestamp(6)
  corporate       Corporate             @relation(fields: [corporateId], references: [corporateId], onDelete: Cascade, onUpdate: NoAction, map: "fk_contact_corporate")
  division        CorporateDivision?    @relation(fields: [divisionId], references: [divisionId], onUpdate: NoAction, map: "fk_contact_division")
  subDivision     CorporateSubDivision? @relation(fields: [subDivisionId], references: [subDivisionId], onUpdate: NoAction, map: "fk_contact_sub_division")
  leads           Lead[]

