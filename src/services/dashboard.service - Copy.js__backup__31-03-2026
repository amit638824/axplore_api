const getLeadCount = async (createdBy, email, dataType) => {
    let where = {};
    const { startDate, endDate } = getDateRange(dataType);
    const conditions = [];
    // Role filter
    const roleFilter = await applyRoleFilter(where, createdBy, email);
    if (roleFilter) conditions.push(roleFilter);

    // Date filter
    if (startDate && endDate) {
        conditions.push({
            createdAt: {
                gte: startDate,
                lte: endDate,
            }
        });
    }
    where = conditions.length > 0 ? { AND: conditions } : {};
    // console.log("wherehhh", JSON.stringify(where, null, 2));
    return await prisma.lead.count({ where }) || 0;
};

