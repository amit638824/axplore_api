// Lead Status Count
const getTotalLeadStatusTime = async (createdBy, email, dataType) => {
    // let where = {};
    // const { startDate, endDate } = getDateRange(dataType);

    // applyRoleFilter(where, createdBy, email);
    // applyDateFilter(where, startDate, endDate);

    let where = {};
    const conditions = [];
    const { startDate, endDate } = getDateRange(dataType);

    // Role filter
    const roleFilter = await applyRoleFilter(where, createdBy, email);
    if (roleFilter) conditions.push(roleFilter);

    // Date filter
    if (startDate && endDate) {
        conditions.push({
            createdAt: {
                gte: startDate,
                lte: endDate,
            }
        });
    }

    where = conditions.length > 0 ? { AND: conditions } : {};

    const grouped = await prisma.lead.groupBy({
        by: ['leadStatusId'],
        where,
        _count: { leadStatusId: true },
    });

    const statusIds = grouped.map(g => g.leadStatusId);

    const statuses = await prisma.masterLeadStatus.findMany({
        where: { leadStatusId: { in: statusIds } }
    });

    return grouped.map(g => {
        const status = statuses.find(s => s.leadStatusId === g.leadStatusId);
        return {
            status_code: status?.statusCode,
            status_name: status?.statusName,
            total: g._count.leadStatusId
        };
    });
};

// Graph (Time-series grouped by Month and Stage)
const getGraph = async (createdBy, email, dataType) => {
    // let where = {};
    // const { startDate, endDate } = getDateRange(dataType);

    // applyRoleFilter(where, createdBy, email);
    // applyDateFilter(where, startDate, endDate);

    let where = {};
    const conditions = [];
    const { startDate, endDate } = getDateRange(dataType);

    // Role filter
    const roleFilter = await applyRoleFilter(where, createdBy, email);
    if (roleFilter) conditions.push(roleFilter);

    // Date filter
    if (startDate && endDate) {
        conditions.push({
            createdAt: {
                gte: startDate,
                lte: endDate,
            }
        });
    }

    where = conditions.length > 0 ? { AND: conditions } : {};

    // Fetch leads with necessary fields
    const leads = await prisma.lead.findMany({
        where,
        select: {
            createdAt: true,
            stage: true,
        },
    });

    // Grouping by Month and Stage in JS
    const grouped = leads.reduce((acc, lead) => {
        if (!lead.stage) return acc;

        // Extract "Jan 26" format for labels
        const d = new Date(lead.createdAt);
        const monthLabel = d.toLocaleDateString("en-GB", { month: "short", year: "2-digit" });
        const sortKey = d.toISOString().slice(0, 7); // "2026-03" for sorting

        const key = `${sortKey}_${lead.stage}`;

        if (!acc[key]) {
            acc[key] = {
                month: monthLabel,
                stage: lead.stage,
                total: 0,
                sortKey
            };
        }
        acc[key].total += 1;
        return acc;
    }, {});

    // Sort by chronological order and return
    return Object.values(grouped).sort((a, b) => a.sortKey.localeCompare(b.sortKey));
};

