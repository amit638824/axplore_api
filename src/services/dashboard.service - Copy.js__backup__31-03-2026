// Get Financial Year Start
const getFinancialYearStart = (now) => {
    const currentYear = now.getFullYear();
    const currentMonth = now.getMonth();
    return currentMonth >= 3 ? currentYear : currentYear - 1;
};

// Get Last Day of Month
const getLastDayOfMonth = (year, month) => {
    return new Date(year, month + 1, 0, 23, 59, 59, 999);
};

// Get Date Range based on type
const getDateRange = (dataType) => {
    const now = new Date();
    const currentYear = now.getFullYear();
    const currentMonth = now.getMonth();
    const fyStartYear = getFinancialYearStart(now);

    let startDate = null;
    let endDate = new Date(now.setHours(23, 59, 59, 999));

    switch (dataType) {
        case "mtd":
            startDate = new Date(currentYear, currentMonth, 1);
            break;

        case "ytd":
            startDate = new Date(fyStartYear, 3, 1);
            break;

        case "q1":
            startDate = new Date(fyStartYear, 3, 1);
            endDate = getLastDayOfMonth(fyStartYear, 5);
            break;

        case "q2":
            startDate = new Date(fyStartYear, 6, 1);
            endDate = getLastDayOfMonth(fyStartYear, 8);
            break;

        case "q3":
            startDate = new Date(fyStartYear, 9, 1);
            endDate = getLastDayOfMonth(fyStartYear, 11);
            break;

        case "q4":
            startDate = new Date(fyStartYear + 1, 0, 1);
            endDate = getLastDayOfMonth(fyStartYear + 1, 2);
            break;

        case "all":
        default:
            startDate = new Date(fyStartYear, 3, 1);
            endDate = getLastDayOfMonth(fyStartYear + 1, 2);
            break;
    }

    return { startDate, endDate };
};

// Apply Date Filter
const applyDateFilter = (where, startDate, endDate) => {
    if (startDate) {
        where.createdAt = {
            gte: startDate,
            lte: endDate,
        };
    }
};

// Role Filter
const applyRoleFilter = async (where, createdBy, email, useRelation = false) => {
    let userId = createdBy;
    const admin = await isAdmin(userId);
    if (admin) {
        return;
    }
    // get full team hierarchy
    const teamUserIds = await getTeamUserIds(userId);
    // where.OR = [
    //     { salesUserId: { in: teamUserIds } },
    //     { contractingHeadUserId: { in: teamUserIds } },
    //     { createdBy: { in: teamUserIds } },
    //     { ops_head_user_id: { in: teamUserIds } },
    // ];


    if (useRelation) {
        where.lead = {
            OR: [
                { salesUserId: { in: teamUserIds } },
                { contractingHeadUserId: { in: teamUserIds } },
                { createdBy: { in: teamUserIds } },
                { ops_head_user_id: { in: teamUserIds } },
            ],
        };
    } else {
        where.OR = [
            { salesUserId: { in: teamUserIds } },
            { contractingHeadUserId: { in: teamUserIds } },
            { createdBy: { in: teamUserIds } },
            { ops_head_user_id: { in: teamUserIds } },
        ];
    }

    return where;
};


